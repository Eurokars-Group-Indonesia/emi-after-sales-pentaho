    <connection>wrs_aftersales</connection>
    <sql>SELECT
	kd_customer,
	nomor_polisi,
	type_customer,
	nama_customer,
	telephone_1,
	telephone_2,
	alamat,
	email,
	no_vin,
	no_mesin,
	fk_model,
	fk_type,
	fk_color,
	tahun,
	tanggal_penyerahan,
	tanggal_last_service,
	fk_dealer,
	status_customer,
	nm_pemakai,
	fk_user_approval,
	tgl_approval,
	status_approval,
	note_approval,
	last_odo_meter,
	fk_religion,
	nm_dpn_pemakai,
	nm_dpn_customer,
	tanggal_lahir,
	counter_repurchase
FROM master_aftersales.tblcustomer
WHERE kd_customer > COALESCE(${last_kd_customer}, 0)
ORDER BY kd_customer ASC
LIMIT 9999</sql>
